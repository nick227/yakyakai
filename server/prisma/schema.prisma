generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PRO
  TEAM
}

enum UsageStatus {
  STARTED
  SUCCESS
  ESTIMATED
  FAILED
  CANCELLED
}

enum JobStatus {
  queued
  running
  paused
  complete
  failed
  cancelled
}

enum MessageRole {
  USER
  ASSISTANT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  avatarUrl    String?
  googleId     String?       @unique
  passwordHash String?
  role         UserRole      @default(USER)
  plan         UserPlan      @default(FREE)
  creditBalance Int          @default(0)
  resetToken   String?       @unique
  resetTokenAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions     AiSession[]
  usageLedger  UsageLedger[]
  creditTransactions CreditTransaction[]

  @@index([email])
}

// ─── Sessions (V2+ auth-gated) ───────────────────────────────────────────────

model AiSession {
  id              String        @id @default(cuid())
  userId          String
  title           String?
  originalPrompt  String        @db.Text
  currentPrompt   String?       @db.Text
  status          String        @default("created")
  promptCount     Int           @default(0)
  cycleCount      Int           @default(0)
  pace            String        @default("steady")
  nextEligibleAt  DateTime      @default(now())
  lastHeartbeatAt DateTime?
  isVisible       Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLedger     UsageLedger[]
  outputs         AiOutput[]
  jobs            Job[]
  events          AiSessionEvent[]
  messages        ChatMessage[]

  @@index([userId, createdAt])
  @@index([userId, updatedAt, id])
  @@index([status, isVisible, nextEligibleAt])
}

model AiOutput {
  id         String    @id @default(cuid())
  sessionId  String
  session    AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cycle      Int       @default(1)
  index      Int
  title      String
  html       String    @db.LongText
  formatType String    @default("strategy_card")
  createdAt  DateTime  @default(now())

  @@index([sessionId, cycle, index])
}

model ChatMessage {
  id         String     @id @default(cuid())
  sessionId  String
  session    AiSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       MessageRole
  content    String     @db.LongText
  metadata   String?    @db.Text
  createdAt  DateTime   @default(now())

  @@index([sessionId, createdAt])
  @@index([sessionId, role])
}

model AiSessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  session   AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  payload   String   @db.LongText
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([sessionId, id])
}

// ─── Usage ────────────────────────────────────────────────────────────────────

model UsageLedger {
  id                     String      @id @default(cuid())
  userId                 String
  sessionId              String?
  jobId                  String?
  phase                  String
  model                  String?
  promptPreview          String?     @db.Text
  promptChars            Int         @default(0)
  estimatedPromptTokens  Int         @default(0)
  actualPromptTokens     Int?
  actualCompletionTokens Int?
  actualTotalTokens      Int?
  status                 UsageStatus @default(STARTED)
  errorCode              String?
  errorMessage           String?     @db.Text
  durationMs             Int?
  createdAt              DateTime    @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  session AiSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([phase])
  @@index([status])
  @@index([userId, sessionId, createdAt])
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id          String     @id @default(cuid())
  userId      String?
  sessionId   String?
  session     AiSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  type        String
  status      JobStatus @default(queued)
  priority    Int       @default(0)
  payloadJson String    @db.LongText
  progress    Int       @default(0)
  currentStep Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lockedAt    DateTime?
  lockedBy    String?
  runAt       DateTime  @default(now())
  lastError   String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@index([lockedAt])
  @@index([userId, createdAt])
  @@index([userId, status])
}

model JobEvent {
  id        String   @id @default(cuid())
  jobId     String
  type      String
  message   String?  @db.Text
  metaJson  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
}

// ─── Intelligence & Memory ────────────────────────────────────────────────────

model PromptAnalysis {
  id              String   @id @default(cuid())
  userId          String?
  sessionId       String?
  prompt          String   @db.Text
  category        String?
  qualityScore    Int      @default(0)
  distinctScore   Int      @default(0)
  tokenRiskScore  Int      @default(0)
  duplicationRisk Int      @default(0)
  issuesJson      String   @db.Text
  suggestionsJson String   @db.Text
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId])
}

model SessionMemory {
  id            String   @id @default(cuid())
  sessionId     String
  summary       String   @db.Text
  factsJson     String   @db.Text
  decisionsJson String   @db.Text
  openLoopsJson String   @db.Text
  sourceCount   Int      @default(0)
  tokenEstimate Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([sessionId, createdAt])
}

// ─── Analytics & Exports ──────────────────────────────────────────────────────

model RunAnalytics {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  eventType String
  value     Int?
  metaJson  String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([eventType])
}

model SavedOutput {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  title     String
  format    String   @default("markdown")
  body      String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([sessionId])
}

// ─── Media ───────────────────────────────────────────────────────────────────────

model AiMediaItem {
  id              Int      @id @default(autoincrement())
  sessionId       String
  cycle           Int
  kind            String
  provider        String
  query           String
  providerAssetId String
  assetJson       String   @db.LongText
  htmlContent     String   @db.LongText
  createdAt       DateTime @default(now())

  @@unique([sessionId, cycle, kind])
  @@index([sessionId])
}

// ─── Credits & Payments ─────────────────────────────────────────────────────────

model CreditTransaction {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount          Int
  packId          String
  stripeSessionId String?            @unique
  status          TransactionStatus  @default(PENDING)
  amountUsd       Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([stripeSessionId])
}
