DATABASE_URL="mysql://root:@127.0.0.1:3306/yakyakai"
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Required for auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Google OAuth — create a Web client ID at console.cloud.google.com
GOOGLE_CLIENT_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

AI_QUEUE_CONCURRENCY=1
AI_QUEUE_SPACING_MS=800
AI_MAX_CONCURRENT=1
AI_TIMEOUT_MS=60000

MAX_PROMPTS_PER_CYCLE=10
AUTO_STOCK_CYCLE=true

FREE_MONTHLY_TOKEN_LIMIT=100000
FREE_MONTHLY_PROMPT_LIMIT=100
HARD_MAX_PROMPT_CHARS=24000
HARD_MAX_PLANNER_TASKS=10

# Email — required for password reset (use any SMTP provider or Mailtrap for dev)
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM="YakyakAI <noreply@yakyakai.com>"

# Worker configuration
MAX_CYCLES=1000
PROCESS_CONCURRENCY=2
WATCHDOG_STALE_TIMEOUT_MS=120000
SSE_POLL_INTERVAL_MS=500
