DATABASE_URL="mysql://root:@127.0.0.1:3306/yakyakai"
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Required for auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 
JWT_SECRET=

# Google OAuth — create a Web client ID at console.cloud.google.com
GOOGLE_CLIENT_ID=

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET= (optional, required for production webhook signature verification)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

AI_QUEUE_CONCURRENCY=1
# Optional: fixed ms between plan steps (overrides pace-based delay). Legacy: AI_QUEUE_SPACING_MS
PLAN_STEP_DELAY_MS=
AI_MAX_CONCURRENT=1
AI_TIMEOUT_MS=60000

MAX_PROMPTS_PER_CYCLE=10
AUTO_STOCK_CYCLE=true

# Media enrichment — Unsplash image search + YouTube video search + Giphy GIFs
UNSPLASH_ACCESS_KEY=
YOUTUBE_API_KEY=
GIPHY_API_KEY=

FREE_MONTHLY_TOKEN_LIMIT=100000
FREE_MONTHLY_PROMPT_LIMIT=100
HARD_MAX_PROMPT_CHARS=24000
HARD_MAX_PLANNER_TASKS=10

# Credits: 1 credit = X tokens (default: 1000 tokens per credit)
CREDITS_PER_TOKEN=1000

# Email — required for password reset (use any SMTP provider or Mailtrap for dev)
MAIL_HOST=live.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM="YakyakAI <noreply@yakyakai.com>"

# Worker configuration
MAX_CYCLES=1000
PROCESS_CONCURRENCY=2
WATCHDOG_STALE_TIMEOUT_MS=120000
SSE_POLL_INTERVAL_MS=500
SESSION_HEARTBEAT_STALE_MS=10000
